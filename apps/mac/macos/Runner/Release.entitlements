<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The engine spawns official CLIs (claude/codex/agy) and reads the login
	     Keychain, which the App Sandbox forbids. WakieAI ships as a local,
	     non-sandboxed helper app (DMG) per PRD §9.2/§16; App Store would instead
	     need a separate non-sandboxed LaunchAgent helper. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
