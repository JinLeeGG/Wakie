<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- dart compile exe binaries map their AOT snapshot as executable
	     memory; under the hardened runtime AMFI SIGKILLs the process at
	     spawn (OS_REASON_CODESIGNING) unless this entitlement is present. -->
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
</dict>
</plist>
